# Zoom App Credentials (from Zoom Marketplace)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URL=https://your-server-domain/api/auth/callback
ZOOM_SECRET_TOKEN=

# Session
SESSION_SECRET=change-me-to-a-random-string

# Database — Neon or Railway PostgreSQL (https://console.neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# AWS Bedrock
AWS_REGION=us-east-1

# RTMS native client (@zoom/rtms) — use same Zoom Marketplace OAuth app as the in-meeting app unless Zoom specifies otherwise
ZM_RTMS_CLIENT=
ZM_RTMS_SECRET=
# Optional: path to CA certificate for TLS to Zoom RTMS servers
# ZM_RTMS_CA=

# Server
PORT=3001
CLIENT_URL=http://localhost:5173
