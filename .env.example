# Zoom App Credentials (from Zoom Marketplace)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URL=https://your-server-domain/api/auth/callback
ZOOM_SECRET_TOKEN=

# Session
SESSION_SECRET=

# Database
DATABASE_URL=

# AWS Bedrock (optional — last resort if OpenAI and CREATE AI fail or are unset)
AWS_REGION=us-east-1

# OpenAI (primary — tried first when OPENAI_API_KEY is set)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# CREATE AI (optional — fallback after OpenAI when URL + token are set)
CREATE_AI_API_URL=https://api-main.aiml.asu.edu/query
CREATE_AI_TOKEN=
CREATE_AI_PRIMARY_MODEL=gemini-pro
CREATE_AI_BACKUP_MODEL=claude-3-opus

# Server
PORT=3001
CLIENT_URL=http://localhost:5173
