# Zoom App Credentials (from Zoom Marketplace)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URL=https://your-server-domain/api/auth/callback
ZOOM_SECRET_TOKEN=

# Session
SESSION_SECRET=change-me-to-a-random-string

# Database — Neon or Railway PostgreSQL (https://console.neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# AI — set OPENAI_API_KEY for OpenAI (recommended), or omit it and use AWS Bedrock below
OPENAI_API_KEY=
# Optional: default https://api.openai.com/v1 — use for OpenAI-compatible proxies
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# AWS Bedrock (only used if OPENAI_API_KEY is not set)
# IAM user/role with bedrock:InvokeModel; enable model in Bedrock → Model access
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# BEDROCK_MODEL_ID=meta.llama3-70b-instruct-v1:0

# RTMS native client (@zoom/rtms) — use same Zoom Marketplace OAuth app as the in-meeting app unless Zoom specifies otherwise
ZM_RTMS_CLIENT=
ZM_RTMS_SECRET=
# Optional: path to CA certificate for TLS to Zoom RTMS servers
# ZM_RTMS_CA=

# Server
PORT=3001
CLIENT_URL=http://localhost:5173
