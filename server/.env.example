# Copy to `.env` in this directory (or: `cp ../.env .` from repo root).
# Prisma CLI loads env from `server/` when you run commands here.

# Zoom App Credentials (from Zoom Marketplace)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URL=https://your-server-domain/api/auth/callback
ZOOM_SECRET_TOKEN=

# Session
SESSION_SECRET=change-me-to-a-random-string

# Database — Neon or Railway PostgreSQL (https://console.neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# AWS Bedrock
AWS_REGION=us-east-1

# RTMS (@zoom/rtms server-side join) — typically same as ZOOM_CLIENT_ID / ZOOM_CLIENT_SECRET
ZM_RTMS_CLIENT=
ZM_RTMS_SECRET=
# ZM_RTMS_CA=

# Server
PORT=3001
CLIENT_URL=http://localhost:5173
